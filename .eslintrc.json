{
  "env": {
    "browser": true,
    "node": true,
    "es2021": true,
    "mocha": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "semi": ["warn", "always"],
    "no-console": "off"
  },
  "globals": {
    "chai": "readonly",
    "toRoman": "readonly",
    "toInt": "readonly",
    "romanRegex": "readonly",
    "handleIntConversion": "readonly",
    "handleRomanConversion": "readonly"
  }
}
